PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/urlshortener
JWT_SECRET=replace-with-strong-secret

# CORS
CORS_ORIGINS=http://localhost:5173

# Public URL used to generate short links (optional)
PUBLIC_BASE_URL=http://localhost:5000

# SMTP (required for OTP emails)
EMAIL_USER=you@example.com
EMAIL_PASS=app-password-or-smtp-password
EMAIL_FROM=URL Shortener <you@example.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false